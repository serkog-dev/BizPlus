# Database
DATABASE_URL="postgresql://bizplus:bizplus123@localhost:5432/bizplus"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (generate with: node -e "require('crypto').generateKeyPairSync('rsa',{modulusLength:2048}).privateKey.export({type:'pkcs8',format:'pem'})")
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Admin JWT (separate keys for super admin)
ADMIN_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_ADMIN_KEY_HERE\n-----END PRIVATE KEY-----"
ADMIN_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_ADMIN_KEY_HERE\n-----END PUBLIC KEY-----"

# App URLs
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"

# WhatsApp Business API (Meta)
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN="bizplus_webhook_secret"

# Twilio (SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Telegram Bot
TELEGRAM_BOT_TOKEN=""

# Encryption key for channel credentials
ENCRYPTION_KEY="your-32-char-encryption-key-here!!"

# Environment
NODE_ENV="development"
PORT=3001

# First Admin Account (used in seed)
